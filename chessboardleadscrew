// --- Add the ENA pin to your definitions ---
const int BUTTON_PIN = 24;
const int LIMIT_SWITCH_1 = 22;
const int LIMIT_SWITCH_2 = 26;
const int DIR_PIN = 5;
const int PUL_PIN = 6;
const int ENA_PIN = 7; // New Enable Pin

// --- State Variables ---
bool isMoving = false;
int currentDirection = HIGH; 
bool lastButtonState = HIGH;

const int pulseDelay = 2; 

void setup() {
  pinMode(BUTTON_PIN, INPUT_PULLUP);
  pinMode(LIMIT_SWITCH_1, INPUT_PULLUP);
  pinMode(LIMIT_SWITCH_2, INPUT_PULLUP);

  pinMode(DIR_PIN, OUTPUT);
  pinMode(PUL_PIN, OUTPUT);
  pinMode(ENA_PIN, OUTPUT); // Set ENA as output

  digitalWrite(DIR_PIN, currentDirection);
  digitalWrite(PUL_PIN, LOW);
  
  // Start with the motor disabled (silent) since it's not moving yet
  digitalWrite(ENA_PIN, LOW); 
}

void loop() {
  bool buttonState = digitalRead(BUTTON_PIN);
  bool ls1State = digitalRead(LIMIT_SWITCH_1);
  bool ls2State = digitalRead(LIMIT_SWITCH_2);

  // 1. Button Press Logic
  if (buttonState == LOW && lastButtonState == HIGH) {
    delay(50);
    if (digitalRead(BUTTON_PIN) == LOW) {
      currentDirection = (currentDirection == HIGH) ? LOW : HIGH;
      digitalWrite(DIR_PIN, currentDirection);
      
      isMoving = true;
      digitalWrite(ENA_PIN, HIGH); // ENABLE the motor right before moving
    }
  }
  lastButtonState = buttonState;

  // 2. Limit Switch Logic
  if (isMoving) {
    if (ls1State == LOW && currentDirection == HIGH) {
      isMoving = false;
      digitalWrite(ENA_PIN, LOW); // DISABLE the motor when stopped
    } 
    else if (ls2State == LOW && currentDirection == LOW) {
      isMoving = false;
      digitalWrite(ENA_PIN, LOW); // DISABLE the motor when stopped
    }
  }

  // 3. Motor Movement Logic
  if (isMoving) {
    digitalWrite(PUL_PIN, HIGH);
    delayMicroseconds(pulseDelay);
    digitalWrite(PUL_PIN, LOW);
    delayMicroseconds(pulseDelay);
  }
}
